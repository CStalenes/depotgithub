pipeline {
    agent any

    stages {
        stage ('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage ('Checkout SCM'){
            steps {
                git branch: 'main', url: 'https://github.com/CStalenes/depotgithub.git'
            }
        }

        stage ('Install Docker'){
            steps{
                sh 'sudo apt-get update'
                sh 'sudo apt-get install docker.io -y'
                sh 'sudo apt install apt-transport-https ca-certificates curl  software-properties-common -y'
                sh 'sudo chmod 666 /var/run/docker.sock'
                sh 'sudo usermod -aG docker $USER'
                sh 'sudo systemctl start docker'
                sh 'sudo systemctl enable docker'

            }
        }

        stage ('Create image docker'){
            steps{
                script {
                    sh 'sudo docker image rm -f "myapp-image:latest"'
                    sh 'sudo docker image build -t "myapp-image:latest" .'
                    sh 'sudo docker image ls'
                }
            }
        }
    }

   
}